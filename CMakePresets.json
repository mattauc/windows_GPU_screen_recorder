{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows / MSVC / vcpkg",
      "description": "Default Windows build using Visual Studio 2022 MSVC and vcpkg manifest mode.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_CXX_STANDARD": "20"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-msvc-ci",
      "inherits": "windows-msvc",
      "displayName": "Windows / MSVC / CI (no NVENC)",
      "description": "CI build with NVENC SDK disabled (not available on GitHub Actions runners).",
      "cacheVariables": {
        "GPUR_BUILD_NVENC": "OFF"
      }
    },
    {
      "name": "windows-ninja-ci",
      "displayName": "Windows / Ninja / CI",
      "description": "CI build using the Ninja generator + MSVC toolchain activated by ilammy/msvc-dev-cmd. Faster and more reliable on GitHub runners than the VS generator.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "20",
        "GPUR_BUILD_NVENC": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc",
      "configuration": "Release"
    },
    {
      "name": "windows-msvc-ci",
      "configurePreset": "windows-msvc-ci",
      "configuration": "Release"
    },
    {
      "name": "windows-ninja-ci",
      "configurePreset": "windows-ninja-ci"
    }
  ],
  "testPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
